  history_index = prefs.getInt("h_idx", 0); web_history_index = prefs.getInt("w_h_idx", 0);
  prefs.getBytes("voc_h", voc_history, sizeof(voc_history));
  prefs.getBytes("tmp_h", temp_history, sizeof(temp_history));
  prefs.getBytes("hum_h", hum_history, sizeof(hum_history));
  prefs.getBytes("prs_h", press_history, sizeof(press_history));
  prefs.getBytes("w_voc_h", web_voc_history, sizeof(web_voc_history));
  prefs.getBytes("w_tmp_h", web_temp_history, sizeof(web_temp_history));
  prefs.getBytes("w_hum_h", web_hum_history, sizeof(web_hum_history));
