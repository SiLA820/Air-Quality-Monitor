void drawRaceGauge(int32_t value) {
  int center_x = 160, center_y = 118, radius = 110;
  int v = (value < 0) ? 0 : ((value > 500) ? 500 : value);
  int active_segments = map(v, 0, 500, 0, 24); 
  for (int i = 0; i < 24; i++) {
    float angle = (180.0 - (i * 7.82)) * 3.14159 / 180.0;
    uint16_t block_color = DARK_PANEL; 
    if (i < active_segments) {
      block_color = (i < 10) ? ST77XX_GREEN : ((i < 19) ? NEON_ORANGE : ST77XX_RED);
    }
    int x_start = center_x + (int)((radius - 12) * cos(angle));
    int y_start = center_y - (int)((radius - 12) * sin(angle));
    int x_end   = center_x + (int)(radius * cos(angle));
    int y_end   = center_y - (int)(radius * sin(angle));
    tft.drawLine(x_start, y_start, x_end, y_end, block_color);
  }
}

uint16_t getEncodedTime() {
  struct tm timeinfo;
  if(!getLocalTime(&timeinfo)){ return 0; }
  return (timeinfo.tm_hour * 100) + timeinfo.tm_min;
}

