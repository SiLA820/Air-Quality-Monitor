  prefs.putUInt("g_mx_pt", g_max_prs_t);  prefs.putUInt("g_mn_p", g_min_prs_t);
  prefs.end();
}

void setup() {
  Serial.begin(115200); delay(1000); 
  prefs.begin("airmon", false); prefs.clear(); prefs.end(); 
  tft.init(240, 320, SPI_MODE3); tft.setRotation(3); tft.invertDisplay(true);      
  tft.setAddrWindow(0, 0, 320, 240); tft.fillScreen(ST77XX_BLACK); 
  WiFi.mode(WIFI_STA); WiFi.setSleep(false); WiFi.begin(ssid, password);
  int w_t = 0; while (WiFi.status() != WL_CONNECTED && w_t < 40) { delay(500); w_t++; }
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  struct tm t_inf; int n_r = 0; while(!getLocalTime(&t_inf) && n_r < 30) { delay(1000); n_r++; }
  ArduinoOTA.setHostname("XIAO-Air-Monitor"); ArduinoOTA.begin();
  Wire.begin(5, 6); Wire.setClock(100000);
  bme_detected = bme.begin(0x76, &Wire); if (!bme_detected) bme_detected = bme.begin(0x77, &Wire); 
  sgp41.begin(Wire); server.on("/", handleRoot); server.begin();
  
  float i_t = bme_detected ? (bme.readTemperature() - 5.5) : 22.0;
  float i_h = bme_detected ? bme.readHumidity() : 45.0;
  float i_p = bme_detected ? (bme.readPressure() / 100.0) : 1013.2;
  
  // FIXED: Linearly spreads fake database timestamps going backward into the past to prevent chart overlap cluttering
  int base_h = t_inf.tm_hour; int base_m = t_inf.tm_min;
  for(int i = 0; i < history_size; i++) { voc_history[i] = 100; temp_history[i] = i_t; hum_history[i] = i_h; press_history[i] = i_p; }
  for(int i = 0; i < web_history_size; i++) { 
    web_voc_history[i] = 100; web_temp_history[i] = i_t; web_hum_history[i] = i_h; web_press_history[i] = i_p; 
    int back_m = base_m - ((web_history_size - 1 - i) * 5);
    int calc_h = base_h + (back_m / 60); int calc_m = back_m % 60;
    if (calc_m < 0) { calc_m += 60; calc_h -= 1; }
    if (calc_h < 0) { calc_h = (calc_h % 24) + 24; }
    web_time_history[i] = ((calc_h % 24) * 100) + calc_m;
  }
  loadSavedHistory();
  tft.fillScreen(ST77XX_BLACK); 
  tft.drawRoundRect(6, 145, 98, 88, 8, DARK_PANEL);   
  tft.drawRoundRect(111, 145, 98, 88, 8, DARK_PANEL); 
  tft.drawRoundRect(216, 145, 98, 88, 8, DARK_PANEL); 
  tft.setTextSize(1); tft.setTextColor(TEXT_MUTED, ST77XX_BLACK); 
  tft.setCursor(120, 115); tft.print("AIR QUALITY"); tft.setCursor(12, 153); tft.print("TEMPERATURE"); tft.setCursor(117, 153); tft.print("HUMIDITY"); tft.setCursor(222, 153); tft.print("PRESSURE");      
}

void loop() {
  server.handleClient(); ArduinoOTA.handle(); 
  const float TEMP_OFFSET = 5.5; 
  static unsigned long l_TFT = 0;
  if (millis() - l_TFT > 500) {
    l_TFT = millis();
    uint16_t v_c = (voc_index > 150) ? ((voc_index > 250) ? ST77XX_RED : NEON_ORANGE) : ST77XX_GREEN; 
    drawRaceGauge(voc_index);
    tft.setTextSize(3); tft.setTextColor(v_c, ST77XX_BLACK); tft.setCursor(130, 80); tft.print(String(voc_index) + " "); 
    tft.setTextSize(1); tft.setCursor(195, 94); tft.print("idx");
    uint16_t t_c = ST77XX_GREEN; if (temp < 19.0) t_c = NEON_CYAN; else if (temp >= 28.0) t_c = ST77XX_RED; else if (temp > 24.5) t_c = NEON_ORANGE; 
    tft.setTextSize(2); tft.setTextColor(t_c, ST77XX_BLACK); tft.setCursor(12, 185); tft.print(String(temp, 1) + "C"); 
    uint16_t h_c = ST77XX_GREEN; if (hum < 35.0) h_c = NEON_ORANGE; else if (hum >= 75.0) h_c = ST77XX_RED; else if (hum > 60.0) h_c = ST77XX_BLUE;   
    tft.setTextSize(2); tft.setTextColor(h_c, ST77XX_BLACK); tft.setCursor(117, 185); tft.print(String(hum, 0) + "%"); 
    tft.setTextSize(2); tft.setTextColor(ST77XX_CYAN, ST77XX_BLACK); tft.setCursor(220, 185); tft.print(String((int)press));
    tft.setTextSize(1); tft.setCursor(220, 208); tft.print("hPa");
    static bool tog = false; tft.fillRect(302, 10, 4, 4, tog ? v_c : ST77XX_BLACK); tog = !tog;
  }
  static unsigned long l_Up = 0;
  if (millis() - l_Up > 1500) {
    l_Up = millis();
    if (bme_detected) {
      float r_t = bme.readTemperature(); float r_h = bme.readHumidity();
      press = bme.readPressure() / 100.0; temp = r_t - TEMP_OFFSET;
      float es_r = 0.6112 * exp((17.67 * r_t) / (r_t + 243.5));
      float e_ac = (r_h / 100.0) * es_r;
      float es_c = 0.6112 * exp((17.67 * temp) / (temp + 243.5));
      hum = (e_ac / es_c) * 100.0; if (hum > 100.0) hum = 100.0; if (hum < 0.0) hum = 0.0;
      uint16_t r_v = 0, r_n = 0;
      uint16_t err = sgp41.measureRawSignals((uint16_t)(hum * 65535 / 100), (uint16_t)((temp + 45) * 65535 / 175), r_v, r_n);
      if (err == 0 && r_v != 0 && r_v != 65535) {
        int32_t r_idx = voc_alg.process(r_v); voc_index = (r_idx <= 0) ? 100 : r_idx;
      } else { voc_index = 100; }
      voc_sum_accumulator += voc_index; temp_sum_accumulator += temp; hum_sum_accumulator += hum; press_sum_accumulator += press; voc_samples_counter++;
    } else { temp = 24.2; hum = 46.0; press = 1013.2; voc_index = 100; }
    voc_history[history_index] = voc_index; temp_history[history_index] = temp; hum_history[history_index] = hum; press_history[history_index] = press;
    history_index = (history_index + 1) % history_size; saveCurrentHistory();
    if (millis() - last20MinUpdate > 10000) { // 10 seconds rapid loop active
      last20MinUpdate = millis();
      int v_avg = (voc_samples_counter > 0) ? (voc_sum_accumulator / voc_samples_counter) : voc_index;
      float t_avg = (voc_samples_counter > 0) ? (temp_sum_accumulator / voc_samples_counter) : temp;
      float h_avg = (voc_samples_counter > 0) ? (hum_sum_accumulator / voc_samples_counter) : hum;
      float p_avg = (voc_samples_counter > 0) ? (press_sum_accumulator / voc_samples_counter) : press;
      uint16_t c_t = getEncodedTime();
      if(v_avg > global_max_voc) { global_max_voc = v_avg; g_max_voc_t = c_t; }
      if(v_avg < global_min_voc || global_min_voc == 999) { global_min_voc = v_avg; g_min_voc_t = c_t; }
      if(t_avg > global_max_tmp) { global_max_tmp = t_avg; g_max_tmp_t = c_t; }
      if(t_avg < global_min_tmp || global_min_tmp == 99.0) { global_min_tmp = t_avg; g_min_tmp_t = c_t; }
      if(h_avg > global_max_hum) { global_max_hum = h_avg; g_max_hum_t = c_t; }
      if(h_avg < global_min_hum || global_min_hum == 101.0) { global_min_hum = h_avg; g_min_hum_t = c_t; }
if(p_avg > global_max_prs) { global_max_prs = p_avg; g_max_prs_t = c_t; }
if(p_avg < global_min_prs || global_min_prs == 9999.0) { global_min_prs = p_avg; 
g_min_prs_t = c_t; }
voc_sum_accumulator = 0; temp_sum_accumulator = 0.0; hum_sum_accumulator = 0.0; 
press_sum_accumulator = 0.0; voc_samples_counter = 0;
web_voc_history[web_history_index] = v_avg; 
web_temp_history[web_history_index] = t_avg; 
web_hum_history[web_history_index] = h_avg; 
web_press_history[web_history_index] = p_avg;
web_time_history[web_history_index] = c_t; saveCurrentHistory();
web_history_index = (web_history_index + 1) % web_history_size;

  }
}
